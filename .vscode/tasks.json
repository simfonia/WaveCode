{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "tauri:dev",
            "type": "shell",
            "command": "cargo",
            "args": ["tauri", "dev"],
            "options": {
                "cwd": "${get:currentWorkspaceFolder}"
            },
            "isBackground": true,
            "problemMatcher": [
                {
                    "owner": "tauri",
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": "Running DevCommand",
                        "endsPattern": "Webview remote debugging (is|available) at"
                    },
                    "pattern": [
                        {
                            "regexp": ".",
                            "file": 1,
                            "location": 2,
                            "message": 3
                        }
                    ]
                }
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
